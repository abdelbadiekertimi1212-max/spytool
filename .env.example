# =============================================================================
# WinnerRadar environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# Only NEXT_PUBLIC_* values are exposed to the browser — keep everything else
# server-side only.
# =============================================================================

# ---- Supabase (Phase 1) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Bypasses RLS. Used by the scraper, cron jobs and webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by the Supabase CLI for migrations / type generation.
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password

# ---- Meta Ad Library (Phase 2 — public website scraper, NO API token) ----
# The engine scrapes the public Ad Library site with Playwright stealth.
META_SEARCH_COUNTRY=DZ
# META_HEADLESS=false   # uncomment to watch the browser while debugging locally

# ---- Scraping resilience (Phase 4 — OFF by default, no paid proxies) ----
ENABLE_PROXY=false
# Comma-separated operator-supplied proxies, e.g. http://user:pass@host:port
PROXY_URLS=
# SCRAPER_BROWSER_POOL=1
# SCRAPER_MAX_SESSION_USES=25

# ---- Groq / Llama 3 (Phase 3) ----
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Resend (Phase 3) ----
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=leads@yourdomain.com

# ---- Chargily Pay V2 (Phase 4) ----
CHARGILY_SECRET_KEY=your-chargily-secret-key
CHARGILY_WEBHOOK_SECRET=your-chargily-webhook-signing-secret
CHARGILY_MODE=test

# ---- Upstash Redis rate limiting (Phase 4) ----
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
